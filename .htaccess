Options -Indexes
DirectoryIndex index.php login.php

# Security
RewriteEngine On

# Protéger les dossiers sensibles
RedirectMatch 403 ^/config/
RedirectMatch 403 ^/includes/
RedirectMatch 403 ^/database/
RedirectMatch 403 ^/lang/

# Redirection de savings.php vers savings_accounts.php
RewriteRule ^savings\.php$ savings_accounts.php [L,R=301]

# Error pages
ErrorDocument 403 /error/403.html
ErrorDocument 404 /error/404.html
ErrorDocument 500 /error/500.html
